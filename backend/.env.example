# Backend ortam değişkenleri — bu dosyayı `.env` olarak kopyalayın ve düzenleyin.
# cp .env.example .env

# API'nin dinleyeceği port
PORT=4000

# CORS için izinli origin. Development için "*", production'da Vercel domain'i.
# Örnek: CORS_ORIGIN=https://smart-beauty.vercel.app
CORS_ORIGIN=*

# Yapay zeka simülasyonu gecikmesi (ms). PDF gereksinimi: 3000.
# Testler veya hızlı debug için düşürülebilir (örn. 100).
SIMULATED_DELAY_MS=3000

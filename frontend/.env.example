# Frontend ortam değişkenleri — bu dosyayı `.env.local` olarak kopyalayın.
# cp .env.example .env.local

# Backend API base URL. NEXT_PUBLIC_ önekiyle tarayıcıdan erişilebilir hale gelir.
# Local development:  http://localhost:4000
# Production:         Render/Railway URL'iniz (ör. https://smart-beauty-api.onrender.com)
NEXT_PUBLIC_API_URL=http://localhost:4000
